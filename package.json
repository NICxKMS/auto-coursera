{
	"name": "auto-coursera",
	"version": "1.1.0",
	"description": "AI-powered answer assistant for e-learning platforms",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "webpack --mode development",
		"build:prod": "webpack --mode production",
		"dev": "webpack --mode development --watch",
		"test": "vitest run",
		"format": "biome format src/ --write",
 		"test:watch": "vitest",
		"lint": "eslint src/ --ext .ts",
		"typecheck": "tsc --noEmit"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/chrome": "^0.0.268",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"copy-webpack-plugin": "^12.0.2",
		"eslint": "^8.57.1",
		"jsdom": "^24.1.3",
		"prettier": "^3.8.1",
		"ts-loader": "^9.5.4",
		"typescript": "^5.9.3",
		"vitest": "^1.6.1",
		"webpack": "^5.105.4",
		"webpack-cli": "^5.1.4"
	}
}
