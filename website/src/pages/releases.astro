---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Base from '../layouts/Base.astro';

// Fetch releases at build time from GitHub API
let releases: Array<{ version: string; date: string; url: string; file: string; size: number }> =
	[];
try {
	const res = await fetch(
		'https://api.github.com/repos/NICxKMS/auto-coursera/releases?per_page=50',
	);
	if (res.ok) {
		const data = await res.json();
		releases = data.map((release: any) => {
			const crxAsset = release.assets?.find((a: any) => a.name.endsWith('.crx'));
			return {
				version: release.tag_name?.replace(/^v/, '') || 'unknown',
				date: release.published_at || release.created_at || '',
				url: crxAsset?.browser_download_url || release.html_url || '',
				file: crxAsset?.name || '',
				size: crxAsset?.size || 0,
			};
		});
	}
} catch {
	// Build continues with empty array — shows "no releases" state
}

function formatDate(dateStr: string): string {
	try {
		const d = new Date(dateStr);
		return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
	} catch {
		return dateStr;
	}
}

function formatSize(bytes: number): string {
	if (bytes < 1024) return `${bytes} B`;
	if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
	return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
}
---

<Base title="Releases" description="Release history for Auto-Coursera Assistant. Download previous versions and see what's changed.">
  <Header />

  <main id="main-content" class="py-16 sm:py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Title -->
      <div class="text-center mb-16 animate-fade-in">
        <p class="section-label">Releases</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Release History</h1>
        <p class="text-lg text-surface-400 max-w-xl mx-auto">
          All published versions of Auto-Coursera Assistant.
        </p>
      </div>

      {releases.length > 0 ? (
        <div class="space-y-4">
          {releases.map((release, i) => (
            <article class="card-interactive relative overflow-hidden animate-slide-up" style={`animation-delay: ${i * 80}ms`}>
              <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-primary-500 via-primary-400/50 to-transparent" aria-hidden="true"></div>
              <div class="flex items-start justify-between gap-4">
                <div class="flex flex-col gap-2 pl-2">
                  <div class="flex items-center gap-3">
                    <h3 class="text-xl font-bold text-white font-mono tracking-tight">v{release.version}</h3>
                    {i === 0 && <span class="badge text-[11px]">Latest</span>}
                  </div>
                  <time datetime={release.date} class="text-sm text-surface-400">{formatDate(release.date)}</time>
                </div>
                <a href={release.url} class="btn-secondary shrink-0 gap-2 px-5 py-2.5 text-sm">
                  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                    <polyline points="7 10 12 15 17 10"></polyline>
                    <line x1="12" y1="15" x2="12" y2="3"></line>
                  </svg>
                  Download
                </a>
              </div>
              {release.size > 0 && (
                <div class="mt-4 pt-4 border-t border-white/[0.04] pl-2">
                  <span class="text-xs text-surface-500 flex items-center gap-1.5">
                    <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
                      <polyline points="14 2 14 8 20 8"></polyline>
                    </svg>
                    {formatSize(release.size)}
                  </span>
                </div>
              )}
            </article>
          ))}
        </div>
      ) : (
        <div class="card text-center py-12">
          <svg class="w-12 h-12 text-surface-600 mx-auto mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
          </svg>
          <h2 class="text-lg font-semibold text-white mb-2">No releases found</h2>
          <p class="text-surface-400 text-sm">Check back later for new releases.</p>
        </div>
      )}
    </div>
  </main>

  <Footer />
</Base>
