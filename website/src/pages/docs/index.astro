---
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import Base from '../../layouts/Base.astro';
---

<Base title="Documentation" description="Documentation hub for Auto-Coursera Assistant. Installation guides, troubleshooting, and more.">
  <Header />

  <main id="main-content" class="py-16 sm:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Title -->
      <div class="text-center mb-16 animate-fade-in">
        <p class="section-label">Docs</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Documentation</h1>
        <p class="text-lg text-surface-400 max-w-xl mx-auto">
          Everything you need to install, configure, and troubleshoot Auto-Coursera Assistant.
        </p>
      </div>

      <!-- ═══════════════════ DOC CARDS ═══════════════════ -->
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-16 animate-slide-up delay-100">
        <!-- Installation Guide -->
        <a href="/install" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Installation Guide</h3>
          <p class="text-sm text-surface-400 leading-relaxed">Download and install with one click. Supports Windows, macOS, and Linux.</p>
        </a>

        <!-- Manual Installation -->
        <a href="/docs/manual" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="4 17 10 11 4 5"></polyline>
              <line x1="12" y1="19" x2="20" y2="19"></line>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Manual Installation</h3>
          <p class="text-sm text-surface-400 leading-relaxed">Step-by-step guide to manually configure browser policies for each OS.</p>
        </a>

        <!-- Troubleshooting -->
        <a href="/docs/troubleshoot" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Troubleshooting</h3>
          <p class="text-sm text-surface-400 leading-relaxed">Common issues and their solutions. Fix problems quickly.</p>
        </a>

        <!-- Downloads -->
        <a href="/downloads" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Downloads</h3>
          <p class="text-sm text-surface-400 leading-relaxed">All platform installers, scripts, and direct downloads in one place.</p>
        </a>

        <!-- Release History -->
        <a href="/releases" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"></polyline>
              <polyline points="8 6 2 12 8 18"></polyline>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Release History</h3>
          <p class="text-sm text-surface-400 leading-relaxed">Browse past releases and download older versions.</p>
        </a>

        <!-- Support -->
        <a href="/support" class="card-interactive group block">
          <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 mb-4 group-hover:bg-primary-500/20 transition-colors">
            <svg class="w-6 h-6 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-white mb-1.5">Support</h3>
          <p class="text-sm text-surface-400 leading-relaxed">FAQ, bug reports, and community help for common questions.</p>
        </a>
      </div>

      <!-- ═══════════════════ QUICK LINKS ═══════════════════ -->
      <section class="animate-slide-up delay-200">
        <div class="glass p-8">
          <h2 class="text-lg font-semibold text-white mb-4">Quick Links</h2>
          <div class="flex flex-wrap gap-3">
            <a href="https://github.com/nicxkms/auto-coursera" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm gap-2 px-5 py-2.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              GitHub Repository
            </a>
            <a href="https://github.com/nicxkms/auto-coursera/issues/new" target="_blank" rel="noopener noreferrer" class="btn-secondary text-sm gap-2 px-5 py-2.5">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              Report an Issue
            </a>
            <a href="/privacy" class="btn-ghost text-sm px-4 py-2.5">
              Privacy Policy
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</Base>
