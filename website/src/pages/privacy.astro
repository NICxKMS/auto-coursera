---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Base from '../layouts/Base.astro';
---

<Base title="Privacy Policy" description="Privacy policy for Auto-Coursera Assistant. No data collection, no tracking, no analytics.">
  <Header />

  <main id="main-content" class="py-16 sm:py-24 px-4">
    <div class="max-w-3xl mx-auto">
      <!-- Title -->
      <div class="text-center mb-16 animate-fade-in">
        <p class="section-label">Legal</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Privacy Policy</h1>
        <p class="text-surface-400">Last updated: March 2026</p>
      </div>

      <!-- Content -->
      <div class="space-y-12 animate-slide-up delay-100">
        <!-- Intro -->
        <section class="glass p-8">
          <p class="text-surface-300 leading-relaxed">
            Auto-Coursera Assistant is committed to protecting your privacy. This policy describes what data we collect (almost none), how it is used, and your rights. We believe privacy is a fundamental right and have designed the extension accordingly.
          </p>
        </section>

        <!-- Extension Data Collection -->
        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-emerald-500/15 text-emerald-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            </span>
            Extension Data Collection
          </h2>
          <div class="glass p-8 space-y-4">
            <p class="text-surface-300 leading-relaxed">
              <strong class="text-white">The extension collects zero personal data.</strong>
            </p>
            <ul class="space-y-3 text-surface-400 text-sm">
              <li class="flex gap-3">
                <span class="text-emerald-400 mt-1 shrink-0">✓</span>
                <span>No personal information is collected or transmitted</span>
              </li>
              <li class="flex gap-3">
                <span class="text-emerald-400 mt-1 shrink-0">✓</span>
                <span>No analytics, no telemetry, no tracking pixels</span>
              </li>
              <li class="flex gap-3">
                <span class="text-emerald-400 mt-1 shrink-0">✓</span>
                <span>No browsing history is recorded or shared</span>
              </li>
              <li class="flex gap-3">
                <span class="text-emerald-400 mt-1 shrink-0">✓</span>
                <span>API keys are stored in Chrome's local storage on your device only</span>
              </li>
              <li class="flex gap-3">
                <span class="text-emerald-400 mt-1 shrink-0">✓</span>
                <span>Quiz data is sent directly from your browser to the AI provider you chose — never to our servers</span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Website Data Collection -->
        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-500/15 text-primary-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
            </span>
            Website Data Collection
          </h2>
          <div class="glass p-8 space-y-4">
            <p class="text-surface-300 leading-relaxed">
              This website is hosted on Cloudflare Pages. We do not use cookies, analytics scripts, or tracking tools.
            </p>
            <p class="text-surface-400 text-sm leading-relaxed">
              Cloudflare may collect standard web server logs (IP address, user agent, accessed URL, timestamps) as part of its hosting infrastructure. These logs are managed by Cloudflare under their <a href="https://www.cloudflare.com/privacypolicy/" target="_blank" rel="noopener noreferrer" class="text-primary-400 hover:text-primary-300">Privacy Policy</a> and are not accessible to us for tracking purposes.
            </p>
          </div>
        </section>

        <!-- Third-Party Services -->
        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-500/15 text-primary-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </span>
            Third-Party Services
          </h2>
          <div class="glass p-8 space-y-4">
            <p class="text-surface-300 leading-relaxed">
              When you use the extension, quiz data is sent to your selected AI provider for answer generation. Each provider has their own privacy policy:
            </p>
            <ul class="space-y-2 text-surface-400 text-sm">
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50 shrink-0"></span>
                <strong class="text-surface-300">OpenRouter</strong> — Routes requests to various AI models
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50 shrink-0"></span>
                <strong class="text-surface-300">Google Gemini</strong> — Google's AI models
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50 shrink-0"></span>
                <strong class="text-surface-300">Groq</strong> — Fast LLM inference
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50 shrink-0"></span>
                <strong class="text-surface-300">Cerebras</strong> — AI accelerator models
              </li>
              <li class="flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-primary-500/50 shrink-0"></span>
                <strong class="text-surface-300">NVIDIA NIM</strong> — NVIDIA's inference microservices
              </li>
            </ul>
            <p class="text-surface-500 text-xs mt-4">
              We encourage you to review each provider's privacy policy before use. The extension sends only the quiz question text and answer options — never your identity, browsing history, or other personal data.
            </p>
          </div>
        </section>

        <!-- Data Storage -->
        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-500/15 text-primary-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            </span>
            Data Storage
          </h2>
          <div class="glass p-8 space-y-4">
            <p class="text-surface-300 leading-relaxed">
              All extension settings and API keys are stored locally in your browser using Chrome's <code>chrome.storage.local</code> API. This data:
            </p>
            <ul class="space-y-2 text-surface-400 text-sm">
              <li class="flex gap-3">
                <span class="text-primary-400 mt-0.5 shrink-0">•</span>
                <span>Never leaves your device (unless you use Chrome sync, which is controlled by your Google account settings)</span>
              </li>
              <li class="flex gap-3">
                <span class="text-primary-400 mt-0.5 shrink-0">•</span>
                <span>Is deleted when you uninstall the extension</span>
              </li>
              <li class="flex gap-3">
                <span class="text-primary-400 mt-0.5 shrink-0">•</span>
                <span>Can be inspected and deleted at any time via <code>chrome://extensions</code></span>
              </li>
            </ul>
          </div>
        </section>

        <!-- Contact -->
        <section>
          <h2 class="text-2xl font-semibold text-white mb-4 flex items-center gap-3">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-500/15 text-primary-400">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            Contact
          </h2>
          <div class="glass p-8">
            <p class="text-surface-300 leading-relaxed">
              If you have questions about this privacy policy or how your data is handled, contact us:
            </p>
            <div class="mt-4 flex flex-col sm:flex-row gap-4">
              <a href="mailto:privacy@nicx.me" class="btn-secondary text-sm gap-2 px-5 py-2.5">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                privacy@nicx.me
              </a>
              <a href="mailto:security@nicx.me" class="btn-secondary text-sm gap-2 px-5 py-2.5">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                security@nicx.me
              </a>
            </div>
          </div>
        </section>
      </div>
    </div>
  </main>

  <Footer />
</Base>
