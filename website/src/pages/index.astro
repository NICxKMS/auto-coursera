---
import ChapterMarker from '../components/ChapterMarker.astro';
import CopyButton from '../components/CopyButton.astro';
import ExtensionMockup from '../components/ExtensionMockup.astro';
import PlatformTabs from '../components/PlatformTabs.astro';
import ProgressRail from '../components/ProgressRail.astro';
import Base from '../layouts/Base.astro';
import '../styles/chapters.css';
---

<Base
	title="AI-Powered Coursera Quiz Assistant"
	description="A browser extension that automatically answers Coursera quiz questions using AI. Free, open source, and privacy-first."
	canonicalPath="/"
>
	<ProgressRail />

	<a href="#the-mechanism" class="skip-link">Skip to how it works</a>
	<a href="#confidence" class="skip-link">Skip to confidence system</a>
	<a href="#get-started" class="skip-link">Skip to get started</a>

	<!-- ================================================================
	     CHAPTER 1 — THE QUIZ
	     ================================================================ -->
	<ChapterMarker chapter={1} id="the-quiz">
		<div class="hero-layout">
			<div class="hero-layout__text">
				<p class="chapter__tagline">
					A browser extension that answers Coursera quizzes using AI
				</p>
				<h1 class="chapter__title">
					The quiz is open.<br />The timer is running.
				</h1>
				<p class="chapter__subtitle">
					Free. <a href="https://github.com/NICxKMS/auto-coursera" target="_blank" rel="noopener noreferrer" class="open-source-link">Open source</a>. One click to every answer.
				</p>
				<div class="chapter__actions">
					<a href="/install/" class="btn btn--primary">Install</a>
					<a href="#the-mechanism" class="btn btn--ghost">See how it works</a>
				</div>

				<div class="chapter__expansion">
					<p>
						Corporate training. Retake attempts. Tricky question formats.
						Whatever brought you here — the quiz is the bottleneck, and you
						need it handled.
					</p>
				</div>
			</div>

			<aside class="install-card" aria-label="Quick install command">
				<div class="install-card__header">
					<span class="install-card__dot" aria-hidden="true"></span>
					<span class="install-card__dot" aria-hidden="true"></span>
					<span class="install-card__dot" aria-hidden="true"></span>
					<span class="install-card__title">Quick install</span>
				</div>
				<div class="install-card__body">
					<div class="install-card__command" data-os="linux">
						<pre><code>curl -fsSL autocr.nicx.me/sh | sh</code></pre>
						<CopyButton text="curl -fsSL autocr.nicx.me/sh | sh" label="Copy Linux install command" />
					</div>
					<div class="install-card__command" data-os="macos">
						<pre><code>curl -fsSL autocr.nicx.me/mac | sh</code></pre>
						<CopyButton text="curl -fsSL autocr.nicx.me/mac | sh" label="Copy macOS install command" />
					</div>
					<div class="install-card__command" data-os="windows">
						<pre><code>irm autocr.nicx.me/ps | iex</code></pre>
						<CopyButton text="irm autocr.nicx.me/ps | iex" label="Copy Windows install command" />
					</div>
				</div>
				<p class="install-card__footnote">
					Works on Linux, macOS &amp; Windows
				</p>
			</aside>
		</div>

		<div class="scroll-hint" aria-hidden="true">
			<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
				<path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
			</svg>
		</div>
	</ChapterMarker>

	<!-- ================================================================
	     CHAPTER 2 — THE MECHANISM
	     ================================================================ -->
	<ChapterMarker chapter={2} id="the-mechanism">
		<h2 class="chapter__title">How it works</h2>

		<div class="mechanism-grid">
			<div class="mechanism-step">
				<span class="mechanism-step__number">300ms</span>
				<p class="mechanism-step__text">
					to detect every question on the page
				</p>
			</div>
			<div class="mechanism-step">
				<span class="mechanism-step__number">800ms</span>
				<p class="mechanism-step__text">
					to batch your entire quiz
				</p>
			</div>
			<div class="mechanism-step">
				<span class="mechanism-step__number">5</span>
				<p class="mechanism-step__text">
					AI providers with automatic failover
				</p>
			</div>
			<div class="mechanism-step">
				<span class="mechanism-step__number">1</span>
				<p class="mechanism-step__text">
					click — answers highlighted in the page
				</p>
			</div>
		</div>

		<ExtensionMockup />
	</ChapterMarker>

	<!-- ================================================================
	     CHAPTER 3 — THE COLORS OF CONFIDENCE
	     ================================================================ -->
	<ChapterMarker chapter={3} id="confidence">
		<h2 class="chapter__title">Confidence at a glance</h2>
		<p class="chapter__body">
			The extension doesn't just answer — it tells you how sure it is.
		</p>

		<div class="confidence-grid">
			<div class="confidence-level confidence-level--green">
				<span class="confidence-level__badge" aria-hidden="true">✓</span>
				<div>
					<strong>High confidence</strong>
					<span class="confidence-level__color-label">Green highlight</span>
					<p>The model is confident in this answer. Auto-selected if you've enabled it.</p>
				</div>
			</div>
			<div class="confidence-level confidence-level--yellow">
				<span class="confidence-level__badge" aria-hidden="true">~</span>
				<div>
					<strong>Review suggested</strong>
					<span class="confidence-level__color-label">Yellow highlight</span>
					<p>Worth checking. Shown but not auto-selected.</p>
				</div>
			</div>
			<div class="confidence-level confidence-level--red">
				<span class="confidence-level__badge" aria-hidden="true">!</span>
				<div>
					<strong>Low confidence</strong>
					<span class="confidence-level__color-label">Red highlight</span>
					<p>The model isn't sure. Flagged for your review.</p>
				</div>
			</div>
		</div>

		<aside class="accuracy-note">
			AI gets it wrong sometimes. The colors help you spot weak answers,
			but they're not a guarantee. Review before you submit — especially
			on graded work.
		</aside>

		<div class="trust-signals">
			<h3>Built for privacy</h3>
			<ul>
				<li>API keys encrypted at rest (AES-256-GCM)</li>
				<li>Shadow DOM isolation — invisible to the page</li>
				<li>No analytics. No telemetry. No user accounts.</li>
				<li>Zero data retention on our end</li>
				<li><a href="https://github.com/NICxKMS/auto-coursera" target="_blank" rel="noopener noreferrer" class="open-source-link">Source code on GitHub</a></li>
			</ul>
		</div>
	</ChapterMarker>

	<!-- ================================================================
	     CHAPTER 4 — GET STARTED
	     ================================================================ -->
	<ChapterMarker chapter={4} id="get-started">
		<h2 class="chapter__title">Get started</h2>
		<p class="chapter__body">
			One command. Five free AI providers. You don't pay for answers.
		</p>

		<PlatformTabs />

		<div class="chapter__actions">
			<a href="/install/" class="btn btn--primary">Full install guide</a>
			<a href="/docs/" class="btn btn--ghost">Read the docs</a>
		</div>
	</ChapterMarker>
</Base>

<script>
	function initOSDetection() {
		const ua = navigator.userAgent.toLowerCase();
		let os = 'linux';
		if (ua.includes('win')) os = 'windows';
		else if (ua.includes('mac')) os = 'macos';

		document
			.querySelectorAll<HTMLElement>('.install-card__command[data-os]')
			.forEach((el) => {
				el.hidden = el.dataset.os !== os;
			});
	}

	initOSDetection();
	document.addEventListener('astro:after-swap', initOSDetection);
</script>

<style>
	/* ==========================================================================
	   Homepage Styles — Scoped to index.astro
	   ========================================================================== */

	/* ===== Chapter 1 — The Quiz ===== */

	.chapter__tagline {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		margin-block-end: var(--space-4);
	}

	.chapter__subtitle {
		font-family: var(--font-body);
		font-size: clamp(1.125rem, 1rem + 0.5vw, 1.375rem);
		font-weight: var(--weight-regular);
		line-height: var(--leading-normal);
		color: var(--text-secondary);
		max-width: var(--content-narrow);
		margin-block-end: var(--space-7);
	}

	.chapter__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-4);
		margin-block-start: var(--space-6);
	}

	.chapter__expansion {
		margin-block-start: var(--space-9);
		max-width: var(--content-narrow);
	}

	.chapter__expansion p {
		color: var(--text-muted);
		font-size: var(--text-body);
		line-height: var(--leading-loose);
	}

	/* ===== Hero Layout — Two-column grid for Chapter 1 ===== */

	.hero-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-8);
		align-items: center;
	}

	@media (min-width: 768px) {
		.hero-layout {
			grid-template-columns: 1fr auto;
			gap: var(--space-7);
		}
	}

	/* ===== Install Card — Terminal-style command card ===== */

	.install-card {
		background-color: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--border-radius);
		overflow: hidden;
		width: 100%;
		max-width: 24rem;
	}

	@media (min-width: 768px) {
		.install-card {
			min-width: 22rem;
		}
	}

	.install-card__header {
		display: flex;
		align-items: center;
		gap: var(--space-2);
		padding: var(--space-3) var(--space-4);
		background-color: var(--surface-hover);
		border-bottom: 1px solid var(--border);
	}

	.install-card__dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		background-color: var(--border);
	}

	.install-card__title {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		color: var(--text-muted);
		margin-inline-start: var(--space-2);
	}

	.install-card__body {
		padding: var(--space-4) var(--space-5);
	}

	.install-card__command {
		display: flex;
		align-items: center;
		gap: var(--space-3);
	}

	.install-card__command[hidden] {
		display: none;
	}

	.install-card__command pre {
		margin: 0;
		background: none;
		border: none;
		border-radius: 0;
		padding: 0;
		flex: 1;
		min-width: 0;
		overflow: hidden;
	}

	.install-card__command code {
		font-family: var(--font-mono);
		font-size: var(--text-code);
		color: var(--accent);
		background: none;
		padding: 0;
		white-space: nowrap;
	}

	.install-card__footnote {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		color: var(--text-muted);
		padding: var(--space-3) var(--space-5);
		padding-block-start: 0;
		margin: 0;
	}

	/* ===== Chapter 2 — Mechanism Grid ===== */

	.mechanism-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
		margin-block-start: var(--space-7);
	}

	.mechanism-step {
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.mechanism-step__number {
		font-family: var(--font-mono);
		font-size: var(--text-h2);
		font-weight: var(--weight-bold);
		font-variant-numeric: tabular-nums;
		color: var(--accent);
		line-height: 1;
	}

	.mechanism-step__text {
		color: var(--text-secondary);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		margin: 0;
	}

	@media (min-width: 640px) {
		.mechanism-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	/* ===== Chapter 3 — Confidence Grid ===== */

	.confidence-grid {
		display: flex;
		flex-direction: column;
		gap: var(--space-5);
		margin-block-start: var(--space-7);
		max-width: var(--content-narrow);
	}

	.confidence-level {
		display: flex;
		align-items: flex-start;
		gap: var(--space-4);
	}

	.confidence-level__badge {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		border-radius: 50%;
		margin-top: 2px;
		font-size: var(--text-small);
		font-weight: var(--weight-bold);
		line-height: 1;
	}

	.confidence-level--green .confidence-level__badge {
		background-color: var(--success);
		color: var(--text-primary);
	}

	.confidence-level--yellow .confidence-level__badge {
		background-color: var(--warning);
		color: #000;
	}

	.confidence-level--red .confidence-level__badge {
		background-color: var(--error);
		color: var(--text-primary);
	}

	.confidence-level__color-label {
		display: block;
		font-family: var(--font-mono);
		font-size: var(--text-small);
		color: var(--text-muted);
		margin-block-end: var(--space-1);
	}

	.confidence-level strong {
		display: block;
		font-family: var(--font-body);
		font-size: var(--text-body);
		font-weight: var(--weight-semibold);
		color: var(--text-primary);
		margin-block-end: 2px;
	}

	.confidence-level p {
		color: var(--text-secondary);
		font-size: var(--text-body);
		line-height: var(--leading-normal);
		margin: 0;
	}

	/* ===== Accuracy Note ===== */

	.accuracy-note {
		margin-block-start: var(--space-7);
		padding-block-start: var(--space-5);
		border-top: 1px solid var(--border);
		max-width: var(--content-narrow);
		color: var(--text-muted);
		font-size: var(--text-body);
		line-height: var(--leading-loose);
		font-style: normal;
	}

	/* ===== Trust Signals ===== */

	.trust-signals {
		margin-block-start: var(--space-8);
		padding: var(--space-6);
		background-color: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--border-radius);
		max-width: var(--content-narrow);
	}

	.trust-signals h3 {
		margin-block-end: var(--space-4);
	}

	.trust-signals ul {
		padding-inline-start: var(--space-5);
		margin: 0;
	}

	.trust-signals li {
		color: var(--text-secondary);
		font-size: var(--text-body);
		margin-block: var(--space-2);
	}

	/* ===== Responsive — small screens ===== */

	@media (max-width: 480px) {
		.chapter__actions {
			flex-direction: column;
			align-items: stretch;
		}

		.btn {
			text-align: center;
		}
	}

	/* ===== FIX-H12 — Scroll Affordance ===== */

	@keyframes scroll-bounce {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(6px); }
	}

	.scroll-hint {
		display: flex;
		justify-content: center;
		margin-block-start: var(--space-8);
		color: var(--text-muted);
		opacity: 0.6;
		animation: scroll-bounce 2s ease-in-out infinite;
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-hint {
			animation: none;
		}
	}

	/* ===== FIX-H13 — Mid-Page CTA Break ===== */

	.chapter__cta-break {
		display: flex;
		justify-content: center;
		width: 100%;
		padding-block-end: var(--space-6);
	}

	/* ===== FIX-H41 — Skip Navigation Links ===== */

	.skip-link {
		position: absolute;
		top: -100%;
		left: var(--space-4);
		z-index: 100;
		padding: var(--space-3) var(--space-5);
		background: var(--accent);
		color: var(--bg-void);
		border-radius: var(--border-radius);
		font-weight: var(--weight-semibold);
		text-decoration: none;
	}

	.skip-link:focus {
		top: var(--space-4);
	}

	/* ===== FIX-H32/H34 — Open Source Link ===== */

	.open-source-link {
		color: var(--accent);
		text-decoration: none;
	}

	.open-source-link:hover {
		text-decoration: underline;
	}
</style>
