---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import VersionBadge from '../components/VersionBadge.astro';
import Base from '../layouts/Base.astro';
---

<Base title="Auto-Coursera Assistant" description="AI-powered answer assistant for e-learning platforms. Get instant, accurate answers on Coursera with multiple AI providers.">
  <Header />

  <main id="main-content">
    <!-- ═══════════════════ HERO ═══════════════════ -->
    <section class="min-h-screen flex items-center justify-center relative px-4 -mt-16 lg:-mt-18">
      <div class="text-center max-w-4xl mx-auto">
        <!-- Version badge -->
        <div class="mb-8 animate-fade-in">
          <VersionBadge />
        </div>

        <!-- Headline -->
        <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 animate-slide-up tracking-tight text-balance">
          Auto-Coursera<br /><span class="text-gradient">Assistant</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-xl md:text-2xl text-surface-400 max-w-2xl mx-auto mb-10 animate-slide-up delay-100 text-balance">
          AI-powered answer assistant for e-learning platforms. Get instant, accurate answers on Coursera.
        </p>

        <!-- CTA buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center animate-slide-up delay-200">
          <a href="/install" class="btn-primary text-lg px-8 py-4">Get Started →</a>
          <a
            href="https://github.com/nicxkms/auto-coursera"
            class="btn-secondary text-lg px-8 py-4 gap-2.5"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
            </svg>
            View on GitHub
          </a>
        </div>
      </div>

      <!-- Scroll indicator -->
      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-float">
        <svg class="w-6 h-6 text-surface-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 5v14"></path>
          <path d="m19 12-7 7-7-7"></path>
        </svg>
      </div>
    </section>

    <!-- ═══════════════════ FEATURES ═══════════════════ -->
    <section class="py-24 px-4">
      <div class="max-w-6xl mx-auto">
        <p class="section-label text-center">Features</p>
        <h2 class="text-3xl md:text-4xl text-center mb-16 text-white">Everything you need</h2>

        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <!-- Feature 1 -->
          <div class="card-interactive animate-slide-up delay-100">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 text-2xl mb-4" aria-hidden="true">🧠</div>
            <h3 class="text-lg font-semibold text-white mb-2">AI-Powered</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Multiple AI providers: OpenRouter, Gemini, Groq, Cerebras, and NVIDIA NIM. Choose the best model for you.</p>
          </div>

          <!-- Feature 2 -->
          <div class="card-interactive animate-slide-up delay-200">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 text-2xl mb-4" aria-hidden="true">⚡</div>
            <h3 class="text-lg font-semibold text-white mb-2">Lightning Fast</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Sub-second responses with smart rate limiting and circuit breakers. Answers appear before you blink.</p>
          </div>

          <!-- Feature 3 -->
          <div class="card-interactive animate-slide-up delay-300">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 text-2xl mb-4" aria-hidden="true">🔒</div>
            <h3 class="text-lg font-semibold text-white mb-2">Privacy First</h3>
            <p class="text-sm text-surface-400 leading-relaxed">API keys stay local. Zero data collection, zero tracking. Your learning stays private.</p>
          </div>

          <!-- Feature 4 -->
          <div class="card-interactive animate-slide-up delay-400">
            <div class="flex items-center justify-center w-12 h-12 rounded-xl bg-primary-500/10 text-2xl mb-4" aria-hidden="true">🎯</div>
            <h3 class="text-lg font-semibold text-white mb-2">Smart Detection</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Auto-detects quiz questions, multiple choice, and assignments. Just open a quiz page and let it work.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ HOW IT WORKS ═══════════════════ -->
    <section class="py-24 px-4">
      <div class="max-w-4xl mx-auto">
        <p class="section-label text-center">How it works</p>
        <h2 class="text-3xl md:text-4xl text-center mb-16 text-white">Three simple steps</h2>

        <div class="grid md:grid-cols-3 gap-8 relative">
          <!-- Connecting line (desktop only) -->
          <div class="hidden md:block absolute top-12 left-[16.67%] right-[16.67%] h-px bg-gradient-to-r from-primary-500/50 via-primary-500/20 to-primary-500/50" aria-hidden="true"></div>

          <!-- Step 1 -->
          <div class="text-center animate-slide-up delay-100">
            <div class="relative inline-flex items-center justify-center w-24 h-24 rounded-2xl glass mb-6">
              <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary-500 text-white text-xs font-bold flex items-center justify-center shadow-glow">1</span>
              <svg class="w-10 h-10 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">Install</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Download for your OS. The installer sets everything up automatically in seconds.</p>
          </div>

          <!-- Step 2 -->
          <div class="text-center animate-slide-up delay-200">
            <div class="relative inline-flex items-center justify-center w-24 h-24 rounded-2xl glass mb-6">
              <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary-500 text-white text-xs font-bold flex items-center justify-center shadow-glow">2</span>
              <svg class="w-10 h-10 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="3"></circle>
                <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"></path>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">Configure</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Add your AI provider API key in the extension popup. Pick your preferred model.</p>
          </div>

          <!-- Step 3 -->
          <div class="text-center animate-slide-up delay-300">
            <div class="relative inline-flex items-center justify-center w-24 h-24 rounded-2xl glass mb-6">
              <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-primary-500 text-white text-xs font-bold flex items-center justify-center shadow-glow">3</span>
              <svg class="w-10 h-10 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-white mb-2">Done</h3>
            <p class="text-sm text-surface-400 leading-relaxed">Open any Coursera quiz — answers appear automatically. It just works.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ BROWSERS ═══════════════════ -->
    <section class="py-24 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <p class="section-label">Compatibility</p>
        <h2 class="text-3xl md:text-4xl mb-4 text-white">Works everywhere</h2>
        <p class="text-surface-400 mb-12">Compatible with all Chromium-based browsers</p>

        <div class="flex flex-wrap justify-center gap-6">
          <!-- Chrome -->
          <div class="card text-center w-36 animate-slide-up delay-100">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-3 rounded-xl bg-white/[0.04]">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="4" fill="#4285F4"/>
                <path d="M12 8a4 4 0 0 1 3.46 2H21a10 10 0 0 0-9-6v6z" fill="#EA4335"/>
                <path d="M15.46 10A4 4 0 0 1 12 16l-4.5 7.79A10 10 0 0 0 21 10h-5.54z" fill="#FBBC05"/>
                <path d="M12 16a4 4 0 0 1-3.46-6L3.04 2.21A10 10 0 0 0 7.5 23.79L12 16z" fill="#34A853"/>
              </svg>
            </div>
            <p class="text-sm text-surface-300 font-medium">Chrome</p>
          </div>

          <!-- Edge -->
          <div class="card text-center w-36 animate-slide-up delay-200">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-3 rounded-xl bg-white/[0.04]">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                <path d="M12 2C6.48 2 2 6.48 2 12c0 2.76 1.12 5.26 2.93 7.07A9.97 9.97 0 0 0 12 22c5.52 0 10-4.48 10-10S17.52 2 12 2z" fill="#0078D4"/>
                <path d="M12 6c-3.31 0-6 2.69-6 6 0 1.66.67 3.16 1.76 4.24L12 12V6z" fill="#50E6FF"/>
              </svg>
            </div>
            <p class="text-sm text-surface-300 font-medium">Edge</p>
          </div>

          <!-- Brave -->
          <div class="card text-center w-36 animate-slide-up delay-300">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-3 rounded-xl bg-white/[0.04]">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                <path d="M12 2L3 7v6c0 5 3.6 9.5 9 10.5 5.4-1 9-5.5 9-10.5V7l-9-5z" fill="#FB542B"/>
                <path d="M12 5l-5 2.8v4.2c0 3.5 2.5 6.6 5 7.3 2.5-.7 5-3.8 5-7.3V7.8L12 5z" fill="#fff"/>
              </svg>
            </div>
            <p class="text-sm text-surface-300 font-medium">Brave</p>
          </div>

          <!-- Chromium -->
          <div class="card text-center w-36 animate-slide-up delay-400">
            <div class="flex items-center justify-center w-12 h-12 mx-auto mb-3 rounded-xl bg-white/[0.04]">
              <svg class="w-7 h-7" viewBox="0 0 24 24" fill="none">
                <circle cx="12" cy="12" r="4" fill="#4587F3"/>
                <path d="M12 8a4 4 0 0 1 3.46 2H21a10 10 0 0 0-9-6v6z" fill="#6EAAFB"/>
                <path d="M15.46 10A4 4 0 0 1 12 16l-4.5 7.79A10 10 0 0 0 21 10h-5.54z" fill="#87BBF8"/>
                <path d="M12 16a4 4 0 0 1-3.46-6L3.04 2.21A10 10 0 0 0 7.5 23.79L12 16z" fill="#5B9CF5"/>
              </svg>
            </div>
            <p class="text-sm text-surface-300 font-medium">Chromium</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ═══════════════════ CTA ═══════════════════ -->
    <section class="py-24 px-4">
      <div class="max-w-3xl mx-auto text-center glass-strong p-12 md:p-16 relative overflow-hidden">
        <!-- Gradient glow behind -->
        <div class="absolute inset-0 bg-gradient-to-r from-primary-600/10 to-indigo-600/10" aria-hidden="true"></div>

        <div class="relative">
          <h2 class="text-3xl md:text-4xl mb-4 text-white">Ready to get started?</h2>
          <p class="text-surface-400 mb-8">Install in under a minute. Free and open source.</p>
          <a href="/install" class="btn-primary text-lg px-10 py-4">Install Now →</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>
