---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import InstallButton from '../components/InstallButton.astro';
import OSDetector from '../components/OSDetector.astro';
import ScriptBlock from '../components/ScriptBlock.astro';
import Base from '../layouts/Base.astro';
---

<Base title="Install" description="Download and install Auto-Coursera Assistant for your operating system. One-click installers for Windows, macOS, and Linux.">
  <Header />
  <OSDetector />

  <main id="main-content" class="py-16 sm:py-24 px-4">
    <div class="max-w-4xl mx-auto">
      <!-- ═══════════════════ TITLE ═══════════════════ -->
      <div class="text-center mb-16 animate-fade-in">
        <p class="section-label">Install</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 tracking-tight">Get Auto-Coursera Assistant</h1>
        <p class="text-lg text-surface-400 max-w-xl mx-auto mb-4">
          One-click install for your platform. The installer handles everything&nbsp;automatically.
        </p>
        <div id="os-badge" class="inline-flex items-center gap-2 px-4 py-2 rounded-full glass text-sm text-surface-300">
          <span class="w-2 h-2 rounded-full bg-surface-600 animate-glow-pulse" id="os-dot"></span>
          <span id="os-label">Detecting your OS…</span>
        </div>
      </div>

      <!-- ═══════════════════ METHOD 1: INSTALLERS ═══════════════════ -->
      <section class="mb-16 animate-slide-up delay-100">
        <div class="flex items-center gap-3 mb-6">
          <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-primary-500/15 text-primary-400 text-sm font-bold">1</span>
          <h2 class="text-xl font-semibold text-white">Download Installer</h2>
          <span class="badge ml-auto">Recommended</span>
        </div>

        <div id="install-buttons" class="grid sm:grid-cols-3 gap-4">
          <div data-install-os="windows">
            <InstallButton os="windows" label="Windows Installer" href="https://api.autocr.nicx.app/api/download/windows" size=".exe — ~8 MB" />
          </div>
          <div data-install-os="macos">
            <InstallButton os="macos" label="macOS Installer" href="https://api.autocr.nicx.app/api/download/macos" size="Universal — ~8 MB" />
          </div>
          <div data-install-os="linux">
            <InstallButton os="linux" label="Linux Installer" href="https://api.autocr.nicx.app/api/download/linux" size="x64 — ~8 MB" />
          </div>
        </div>
      </section>

      <!-- ═══════════════════ METHOD 2: TERMINAL ═══════════════════ -->
      <section class="mb-16 animate-slide-up delay-200">
        <details class="group" id="terminal-section">
          <summary class="flex items-center gap-3 mb-6 cursor-pointer list-none select-none">
            <span class="flex items-center justify-center w-8 h-8 rounded-lg bg-surface-800 text-surface-400 text-sm font-bold group-open:bg-primary-500/15 group-open:text-primary-400 transition-colors">2</span>
            <h2 class="text-xl font-semibold text-white">Install via Terminal</h2>
            <svg class="w-5 h-5 text-surface-500 ml-auto transition-transform duration-200 group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>

          <div id="script-blocks" class="space-y-6 pl-11">
            <div data-script-os="windows">
              <ScriptBlock command="irm https://autocr.nicx.app/scripts/install.ps1 | iex" label="Windows (PowerShell)" />
            </div>
            <div data-script-os="linux">
              <ScriptBlock command="curl -fsSL https://autocr.nicx.app/scripts/install.sh | sudo bash" label="Linux" />
            </div>
            <div data-script-os="macos">
              <ScriptBlock command="curl -fsSL https://autocr.nicx.app/scripts/install-mac.sh | bash" label="macOS" />
            </div>
          </div>
        </details>
      </section>

      <!-- ═══════════════════ WHAT HAPPENS NEXT ═══════════════════ -->
      <section class="animate-slide-up delay-300">
        <div class="glass-strong p-8 md:p-10 relative overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-primary-600/5 to-transparent" aria-hidden="true"></div>
          <div class="relative">
            <h2 class="text-xl font-semibold text-white mb-6 flex items-center gap-2">
              <svg class="w-5 h-5 text-primary-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M12 16v-4"></path>
                <path d="M12 8h.01"></path>
              </svg>
              What happens after install?
            </h2>

            <ol class="space-y-5">
              <li class="flex gap-4">
                <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-500/15 text-primary-400 text-xs font-bold shrink-0 mt-0.5">1</span>
                <div>
                  <p class="text-surface-200 font-medium">Extension is installed automatically</p>
                  <p class="text-sm text-surface-500">The installer registers a browser policy that force-installs the extension.</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-500/15 text-primary-400 text-xs font-bold shrink-0 mt-0.5">2</span>
                <div>
                  <p class="text-surface-200 font-medium">Restart your browser</p>
                  <p class="text-sm text-surface-500">Close and reopen Chrome (or your Chromium browser) to activate the extension.</p>
                </div>
              </li>
              <li class="flex gap-4">
                <span class="flex items-center justify-center w-7 h-7 rounded-full bg-primary-500/15 text-primary-400 text-xs font-bold shrink-0 mt-0.5">3</span>
                <div>
                  <p class="text-surface-200 font-medium">Add your API key</p>
                  <p class="text-sm text-surface-500">Click the extension icon and enter your AI provider API key. That's&nbsp;it&nbsp;—&nbsp;you're&nbsp;ready.</p>
                </div>
              </li>
            </ol>
          </div>
        </div>
      </section>

      <!-- ═══════════════════ HELP ═══════════════════ -->
      <div class="mt-12 text-center animate-slide-up delay-400">
        <p class="text-surface-500 text-sm">
          Having trouble? Check the <a href="/docs/troubleshoot" class="text-primary-400 hover:text-primary-300">troubleshooting guide</a>
          or <a href="/docs/manual" class="text-primary-400 hover:text-primary-300">install manually</a>.
        </p>
      </div>
    </div>
  </main>

  <Footer />
</Base>

<script>
  document.addEventListener('os-detected', (e: Event) => {
    const { os } = (e as CustomEvent<{ os: string }>).detail;
    if (os === 'unknown') return;

    // Update OS badge
    const dot = document.getElementById('os-dot');
    const label = document.getElementById('os-label');
    if (dot) dot.classList.replace('bg-surface-600', 'bg-emerald-400');
    const names: Record<string, string> = { windows: 'Windows', macos: 'macOS', linux: 'Linux' };
    if (label) label.textContent = `Detected: ${names[os] || os}`;

    // Reorder install buttons — move detected OS first
    const container = document.getElementById('install-buttons');
    if (container) {
      const detected = container.querySelector(`[data-install-os="${os}"]`);
      if (detected) {
        container.prepend(detected);
        // Mark as recommended
        const card = detected.querySelector('.install-card');
        if (card && !card.classList.contains('border-primary-500/25')) {
          card.classList.remove('glass', 'hover:bg-white/[0.05]', 'hover:border-white/[0.12]', 'hover:shadow-glow');
          card.classList.add('bg-gradient-to-r', 'from-primary-600/20', 'to-primary-500/10', 'border', 'border-primary-500/25', 'shadow-lg', 'shadow-primary-500/10', 'hover:shadow-glow-lg', 'hover:border-primary-400/40');
        }
      }
    }

    // Reorder script blocks — detected OS first
    const scriptContainer = document.getElementById('script-blocks');
    if (scriptContainer) {
      const detectedScript = scriptContainer.querySelector(`[data-script-os="${os}"]`);
      if (detectedScript) scriptContainer.prepend(detectedScript);
    }
  });
</script>
