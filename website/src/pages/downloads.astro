---
import versionInfo from '@root/version.json';
import Breadcrumb from '../components/Breadcrumb.astro';
import Base from '../layouts/Base.astro';

// Build-time domain reference: versionInfo.domains.website
const siteUrl = versionInfo.domains.website;
---

<Base
	title="Downloads — Auto-Coursera Installers for All Platforms"
	description="Download Auto-Coursera installers for Windows, macOS, and Linux. Available for x64 and ARM64 architectures."
	canonicalPath="/downloads/"
>
	<!-- ================================================================
	     HERO
	     ================================================================ -->
	<section class="hero" data-bg="deep" aria-labelledby="downloads-heading">
		<div class="container-narrow">
			<p class="hero__product">Auto-Coursera — AI-powered Coursera quiz assistant</p>
			<Breadcrumb items={[{ label: 'Home', href: '/' }, { label: 'Downloads' }]} />
			<h1 id="downloads-heading">Downloads</h1>
			<div class="hero__meta">
				<span class="version-badge">v{versionInfo.version}</span>
				<span class="hero__separator" aria-hidden="true">&middot;</span>
				<span class="hero__note">Free &amp; open source</span>
			</div>
			<p class="hero__lead">
				Grab a platform installer for Windows, macOS, or Linux.
				Available for both <strong>x64</strong> and <strong>ARM64</strong>
				architectures.
			</p>
			<p class="hero__links">
				Looking for the one-command install?
				<a href="/install/">Install page</a>. Want to build from source?
				<a href="/docs/manual/">Manual install guide</a>.
			</p>
		</div>
	</section>

	<!-- ================================================================
	     PLATFORM DOWNLOAD GRID
	     ================================================================ -->
	<section class="section" data-bg="void" aria-labelledby="installers-heading">
		<div class="container">
			<h2 id="installers-heading">Platform installers</h2>
			<p>Download the installer for your operating system and architecture.</p>
			<p class="detected-hint" id="detected-hint" hidden>Based on your system</p>

			<!-- App / Zip toggle -->
			<div class="download-toggle" role="tablist" aria-label="Download format">
				<button
					id="toggle-app"
					class="download-toggle__btn"
					role="tab"
					data-view="app"
					aria-controls="view-app"
					aria-selected="true"
					tabindex="0"
				>
					App
				</button>
				<button
					id="toggle-zip"
					class="download-toggle__btn"
					role="tab"
					data-view="zip"
					aria-controls="view-zip"
					aria-selected="false"
					tabindex="-1"
				>
					Zip
				</button>
			</div>

			<!-- App view: platform installer cards -->
			<div id="view-app" role="tabpanel" aria-labelledby="toggle-app" data-view="app">
			<div class="download-grid">
				<div class="download-card" data-os="windows" data-arch="x64">
					<h3 class="download-card__platform">Windows</h3>
					<p class="download-card__arch">x64 (Intel/AMD)</p>
					<a href="/download/windows" class="download-card__btn">Download</a>
				</div>

				<div class="download-card" data-os="windows" data-arch="arm64">
					<h3 class="download-card__platform">Windows</h3>
					<p class="download-card__arch">ARM (64-bit)</p>
					<a href="/download/windows-arm64" class="download-card__btn">Download</a>
				</div>

				<div class="download-card" data-os="macos" data-arch="arm64">
					<h3 class="download-card__platform">macOS</h3>
					<p class="download-card__arch">Apple Silicon</p>
					<a href="/download/macos" class="download-card__btn">Download</a>
				</div>

				<div class="download-card" data-os="macos" data-arch="x64">
					<h3 class="download-card__platform">macOS</h3>
					<p class="download-card__arch">Intel / AMD (64-bit)</p>
					<a href="/download/macos-intel" class="download-card__btn">Download</a>
				</div>

				<div class="download-card" data-os="linux" data-arch="x64">
					<h3 class="download-card__platform">Linux</h3>
					<p class="download-card__arch">x64 (Intel/AMD)</p>
					<a href="/download/linux" class="download-card__btn">Download</a>
				</div>

				<div class="download-card" data-os="linux" data-arch="arm64">
					<h3 class="download-card__platform">Linux</h3>
					<p class="download-card__arch">ARM (64-bit)</p>
					<a href="/download/linux-arm64" class="download-card__btn">Download</a>
				</div>
			</div>
			</div>

			<!-- Zip view: extension package download -->
			<div id="view-zip" role="tabpanel" aria-labelledby="toggle-zip" data-view="zip" hidden>
				<div class="download-grid">
					<div class="download-card download-card--wide">
						<h3 class="download-card__platform">Extension Package (.zip)</h3>
						<p class="download-card__desc">
							Download the extension as a zip archive containing the
							built extension and <code>.crx</code> file. Load as an
							unpacked extension in Chrome.
						</p>
						<a
							href={`https://github.com/${versionInfo.githubRepo}/releases/latest/download/auto-coursera.zip`}
							class="download-card__btn"
							rel="noopener noreferrer"
						>
							Download .zip
						</a>

						<div class="zip-instructions">
							<h4 class="zip-instructions__heading">How to install</h4>
							<ol class="zip-instructions__steps">
								<li>Download and extract the zip</li>
								<li>Open <code>chrome://extensions</code> in your browser</li>
								<li>Enable <strong>Developer mode</strong> (top-right toggle)</li>
								<li>Click <strong>Load unpacked</strong> and select the extracted folder</li>
							</ol>
							<p class="zip-instructions__note">
								The archive contains the built <code>dist</code> folder
								and a <code>.crx</code> file for manual installation.
							</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- ================================================================
	     SYSTEM REQUIREMENTS
	     ================================================================ -->
	<section class="section" data-bg="deep" aria-labelledby="requirements-heading">
		<div class="container-narrow">
			<h2 id="requirements-heading">System requirements</h2>
			<ul class="requirements-list">
				<li>
					<strong>A Chromium-based browser</strong> — Chrome, Edge,
					Brave, or any other Chromium derivative.
				</li>
				<li>
					<strong>An API key</strong> from a supported AI provider
					(OpenRouter, Google Gemini, Groq, Cerebras, or NVIDIA NIM). Free
					tiers are available. See the
					<a href="/docs/setup/">setup guide</a>.
				</li>
			</ul>
		</div>
	</section>

	<!-- ================================================================
	     TERMINAL CROSS-REFERENCE
	     ================================================================ -->
	<section class="section" data-bg="void">
		<div class="container-narrow">
			<h2>Prefer a terminal command?</h2>
			<p>The <a href="/install/">install page</a> has a single-command installer for Linux, macOS, and Windows — with automatic browser setup included.</p>
		</div>
	</section>

	<!-- ================================================================
	     BUILD FROM SOURCE
	     ================================================================ -->
	<section class="section" data-bg="deep" aria-labelledby="source-heading">
		<div class="container-narrow">
			<h2 id="source-heading">Build from source</h2>
			<p>
				Want full control? Clone the repository and build the extension
				yourself. The
				<a href="/docs/manual/">manual install guide</a> walks you
				through the process step by step.
			</p>
			<p>
				Source code:
				<a href={`https://github.com/${versionInfo.githubRepo}`} target="_blank" rel="noopener noreferrer">github.com/{versionInfo.githubRepo}</a>
			</p>
		</div>
	</section>

	<!-- ================================================================
	     DOWNLOAD TOGGLE SCRIPT
	     ================================================================ -->
	<script>
		function initDownloadToggle() {
			const tabs = document.querySelectorAll<HTMLButtonElement>('.download-toggle__btn');
			const panels = document.querySelectorAll<HTMLElement>('[role="tabpanel"][data-view]');
			if (!tabs.length || !panels.length) return;

			function activate(view: string) {
				tabs.forEach((tab) => {
					const isActive = tab.dataset.view === view;
					tab.setAttribute('aria-selected', String(isActive));
					tab.tabIndex = isActive ? 0 : -1;
				});
				panels.forEach((panel) => {
					panel.hidden = panel.dataset.view !== view;
				});
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					if (tab.dataset.view) activate(tab.dataset.view);
				});
			});

			// Keyboard navigation (arrow keys within tablist)
			const tablist = document.querySelector<HTMLElement>('.download-toggle');
			tablist?.addEventListener('keydown', (e) => {
				const views = ['app', 'zip'];
				const current = document.querySelector<HTMLButtonElement>(
					'.download-toggle__btn[aria-selected="true"]'
				);
				if (!current) return;

				const idx = views.indexOf(current.dataset.view ?? '');
				let next = -1;

				if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
					e.preventDefault();
					next = (idx + 1) % views.length;
				} else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
					e.preventDefault();
					next = (idx - 1 + views.length) % views.length;
				} else if (e.key === 'Home') {
					e.preventDefault();
					next = 0;
				} else if (e.key === 'End') {
					e.preventDefault();
					next = views.length - 1;
				}

				if (next >= 0) {
					activate(views[next]);
					const nextTab = document.querySelector<HTMLButtonElement>(
						`.download-toggle__btn[data-view="${views[next]}"]`
					);
					nextTab?.focus();
				}
			});

			// Reset to default on init
			activate('app');
		}

		function detectOS(): { os: string; arch: string } {
			const ua = navigator.userAgent.toLowerCase();
			let os = 'linux';
			let arch = 'x64';

			if (ua.includes('win')) {
				os = 'windows';
			} else if (ua.includes('mac')) {
				os = 'macos';
			}

			// Detect ARM architecture
			if (ua.includes('aarch64') || ua.includes('arm64') || ua.includes('arm')) {
				arch = 'arm64';
			}

			return { os, arch };
		}

		function highlightRecommended() {
			// Clear previous recommendations
			const prev = document.querySelectorAll<HTMLElement>('.download-card[data-recommended]');
			prev.forEach((card) => card.removeAttribute('data-recommended'));

			const { os, arch } = detectOS();

			// For macOS, default to Apple Silicon (arm64) unless Intel detected
			const targetArch = os === 'macos' && arch === 'x64' ? 'x64' : os === 'macos' ? 'arm64' : arch;

			const selector = `.download-card[data-os="${os}"][data-arch="${targetArch}"]`;
			const card = document.querySelector<HTMLElement>(selector);
			if (card) {
				card.setAttribute('data-recommended', '');
			}

			// Show the detected-hint text
			const hint = document.getElementById('detected-hint');
			if (hint && card) {
				hint.hidden = false;
			}
		}

		initDownloadToggle();
		highlightRecommended();
		document.addEventListener('astro:after-swap', () => {
			initDownloadToggle();
			highlightRecommended();
		});
	</script>
</Base>

<style>
	/* ==========================================================================
	   Downloads Page — Scoped Styles
	   ========================================================================== */

	/* ===== Hero ===== */

	.hero {
		padding-block-start: calc(var(--nav-height) + var(--space-7));
		padding-block-end: var(--space-6);
		background-color: var(--bg-deep);
	}

	.hero h1 {
		margin-block-end: var(--space-4);
	}

	.hero__product {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-block-end: var(--space-2);
	}

	.hero__lead {
		font-size: clamp(1.0625rem, 1rem + 0.25vw, 1.1875rem);
		max-width: 36rem;
	}

	.hero__lead strong {
		color: var(--text-primary);
		font-weight: var(--weight-semibold);
	}

	.hero__links {
		font-size: var(--text-small);
		color: var(--text-muted);
	}

	.hero__meta {
		display: flex;
		align-items: center;
		gap: var(--space-3);
		margin-block-end: var(--space-5);
		flex-wrap: wrap;
	}

	.version-badge {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--accent);
		background-color: var(--accent-subtle);
		padding: var(--space-1) var(--space-3);
		border-radius: var(--border-radius-sm);
		line-height: 1;
	}

	.hero__separator {
		color: var(--text-muted);
	}

	.hero__note {
		font-size: var(--text-small);
		color: var(--text-muted);
	}

	/* ===== Sections ===== */

	.section {
		padding-block: var(--space-6);
	}

	.section h2 {
		margin-block-end: var(--space-4);
	}

	.section h3 {
		margin-block-start: var(--space-6);
		margin-block-end: var(--space-3);
	}

	/* ===== Download Toggle ===== */

	.download-toggle {
		display: inline-flex;
		gap: 0;
		border: 1px solid var(--border);
		border-radius: var(--border-radius-sm);
		overflow: hidden;
		margin-block-start: var(--space-4);
	}

	.download-toggle__btn {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.03em;
		text-transform: uppercase;
		color: var(--text-muted);
		background: transparent;
		border: none;
		padding: var(--space-2) var(--space-5);
		cursor: pointer;
		transition:
			background-color var(--transition-fast),
			color var(--transition-fast);
		line-height: 1;
	}

	.download-toggle__btn:hover {
		color: var(--text-secondary);
		background-color: var(--surface-hover);
	}

	.download-toggle__btn[aria-selected='true'] {
		background-color: var(--accent);
		color: var(--bg-void);
	}

	/* ===== Zip Card (wide variant) ===== */

	.download-card--wide {
		grid-column: 1 / -1;
	}

	.download-card__desc {
		font-size: var(--text-small);
		color: var(--text-secondary);
		line-height: var(--leading-normal);
		margin: 0;
	}

	.download-card__desc code {
		font-size: var(--text-code);
	}

	/* ===== Zip Instructions ===== */

	.zip-instructions {
		margin-block-start: var(--space-4);
		padding-block-start: var(--space-4);
		border-top: 1px solid var(--border);
	}

	.zip-instructions__heading {
		font-family: var(--font-body);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		color: var(--text-primary);
		margin: 0 0 var(--space-3) 0;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.zip-instructions__steps {
		margin: 0;
		padding-inline-start: var(--space-5);
	}

	.zip-instructions__steps li {
		font-size: var(--text-small);
		color: var(--text-secondary);
		line-height: var(--leading-normal);
		margin-block: var(--space-2);
	}

	.zip-instructions__steps code {
		font-size: var(--text-code);
		color: var(--text-primary);
	}

	.zip-instructions__steps strong {
		color: var(--text-primary);
	}

	.zip-instructions__note {
		font-size: var(--text-small);
		color: var(--text-muted);
		margin-block-start: var(--space-3);
		margin-block-end: 0;
	}

	.zip-instructions__note code {
		font-size: var(--text-code);
	}

	/* ===== Download Grid ===== */

	.download-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-4);
		margin-block-start: var(--space-5);
	}

	.download-card {
		background-color: var(--surface);
		border: 1px solid var(--border);
		border-radius: var(--border-radius);
		padding: var(--space-5);
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
		transition:
			background-color var(--transition-fast),
			border-color var(--transition-fast);
	}

	.download-card:hover {
		background-color: var(--surface-hover);
		border-color: var(--border-accent);
	}

	/* ===== Recommended Badge (OS Detection) ===== */

	.download-card[data-recommended] {
		border-color: var(--accent);
		position: relative;
	}

	.download-card[data-recommended]::after {
		content: 'Recommended';
		position: absolute;
		top: calc(-1 * var(--space-2));
		right: var(--space-3);
		padding: var(--space-1) var(--space-2);
		font-family: var(--font-mono);
		font-size: var(--text-small);
		color: var(--bg-void);
		background-color: var(--accent);
		border-radius: var(--border-radius-sm);
	}

	.detected-hint {
		font-size: var(--text-small);
		color: var(--text-muted);
		font-family: var(--font-mono);
		margin-block-start: var(--space-2);
	}

	.download-card__platform {
		font-family: var(--font-body);
		font-size: var(--text-h3);
		font-weight: var(--weight-bold);
		color: var(--text-primary);
		margin: 0;
	}

	.download-card__arch {
		font-size: var(--text-small);
		color: var(--text-muted);
		margin: 0;
	}

	.download-card__btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-semibold);
		letter-spacing: 0.03em;
		text-transform: uppercase;
		text-decoration: none;
		padding: var(--space-2) var(--space-4);
		border: 1px solid var(--accent);
		border-radius: var(--border-radius-sm);
		color: var(--accent);
		background: transparent;
		margin-block-start: var(--space-2);
		align-self: flex-start;
		transition:
			background-color var(--transition-fast),
			color var(--transition-fast);
		line-height: 1;
	}

	.download-card__btn:hover {
		background-color: var(--accent);
		color: var(--bg-void);
		text-decoration: none;
	}

	@media (min-width: 640px) {
		.download-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 960px) {
		.download-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	/* ===== Requirements ===== */

	.requirements-list {
		margin-block-start: var(--space-4);
		padding-inline-start: var(--space-5);
	}

	.requirements-list li {
		margin-block: var(--space-3);
		color: var(--text-secondary);
		line-height: var(--leading-normal);
	}

	.requirements-list strong {
		color: var(--text-primary);
	}

	/* ===== Responsive ===== */

	@media (max-width: 480px) {
		.hero {
			padding-block-start: calc(var(--nav-height) + var(--space-6));
			padding-block-end: var(--space-5);
		}
	}
</style>
