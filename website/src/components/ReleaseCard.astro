---
interface Props {
	version: string;
	date: string;
	downloadUrl: string;
	size?: string;
	latest?: boolean;
}

const { version, date, downloadUrl, size, latest = false } = Astro.props;

function formatDate(dateStr: string): string {
	try {
		const d = new Date(dateStr);
		return d.toLocaleDateString('en-US', {
			year: 'numeric',
			month: 'long',
			day: 'numeric',
		});
	} catch {
		return dateStr;
	}
}

const formattedDate = formatDate(date);
---

<article class="card-interactive relative overflow-hidden">
  <!-- Left gradient accent -->
  <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-gradient-to-b from-primary-500 via-primary-400/50 to-transparent" aria-hidden="true"></div>

  <div class="flex items-start justify-between gap-4">
    <!-- Version & Date -->
    <div class="flex flex-col gap-2 pl-2">
      <div class="flex items-center gap-3">
        <h3 class="text-xl font-bold text-white font-mono tracking-tight">
          v{version}
        </h3>
        {latest && (
          <span class="badge text-[11px]">Latest</span>
        )}
      </div>
      <time datetime={date} class="text-sm text-surface-400">
        {formattedDate}
      </time>
    </div>

    <!-- Download button -->
    <a
      href={downloadUrl}
      class="btn-secondary shrink-0 gap-2 px-5 py-2.5 text-sm"
    >
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      Download
    </a>
  </div>

  {size && (
    <div class="mt-4 pt-4 border-t border-white/[0.04] pl-2">
      <span class="text-xs text-surface-500 flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
          <polyline points="14 2 14 8 20 8"></polyline>
        </svg>
        {size}
      </span>
    </div>
  )}
</article>
