---
import versionInfo from '@root/version.json';

const currentYear = new Date().getFullYear();
---

<footer class="footer">
	<div class="footer__inner container">
		<div class="footer__brand">
			<span class="footer__logo">AC</span>
			<p class="footer__tagline">
				AI-powered Coursera quiz assistant.<br />Free. Open source.
			</p>
		</div>

		<div class="footer__columns">
			<div class="footer__column">
				<h3 class="footer__heading">Product</h3>
				<ul role="list">
					<li><a href="/install/">Install</a></li>
					<li><a href="/downloads/">Downloads</a></li>
					<li><a href="/releases/">What's New</a></li>
					<li><a href="/support/">Support</a></li>
					<li>
						<a
							href={`https://github.com/${versionInfo.githubRepo}`}
							target="_blank"
							rel="noopener noreferrer"
							class="footer__external"
						>
							GitHub
						</a>
					</li>
				</ul>
			</div>

			<div class="footer__column">
				<h3 class="footer__heading">Documentation</h3>
				<ul role="list">
					<li><a href="/docs/">Getting Started</a></li>
					<li><a href="/docs/setup/">Setup Guide</a></li>
					<li><a href="/docs/manual/">Manual Install</a></li>
					<li><a href="/docs/troubleshoot/">Troubleshooting</a></li>
					<li><a href="/docs/architecture/">Architecture</a></li>
				</ul>
			</div>

			<div class="footer__column">
				<h3 class="footer__heading">Legal</h3>
				<ul role="list">
					<li><a href="/privacy/">Privacy</a></li>
					<li><a href="/terms/">Terms</a></li>
					<li>
						<a
							href={`https://github.com/${versionInfo.githubRepo}/blob/master/LICENSE`}
							target="_blank"
							rel="noopener noreferrer"
							class="footer__external"
						>
							License
						</a>
					</li>
				</ul>
			</div>
		</div>

		<div class="footer__bottom">
			<p>
				&copy; {currentYear} Auto-Coursera <span class="footer__version">v{versionInfo.version}</span>. Built by
				<a
					href="https://github.com/NICxKMS"
					target="_blank"
					rel="noopener noreferrer"
					class="footer__bottom-link"
				>NICxKMS</a> — open source on
				<a
					href={`https://github.com/${versionInfo.githubRepo}`}
					target="_blank"
					rel="noopener noreferrer"
					class="footer__bottom-link"
				>GitHub</a>
			</p>
		</div>
	</div>
</footer>

<style>
	.footer {
		background-color: var(--bg-void);
		border-top: 1px solid var(--border);
		padding-block-start: var(--space-9);
		padding-block-end: var(--space-7);
	}

	.footer__inner {
		display: flex;
		flex-direction: column;
		gap: var(--space-7);
	}

	/* --- Brand --- */

	.footer__logo {
		display: inline-block;
		font-family: var(--font-mono);
		font-weight: var(--weight-bold);
		font-size: var(--text-h3);
		color: var(--accent);
		line-height: 1;
		margin-block-end: var(--space-3);
	}

	.footer__tagline {
		color: var(--text-secondary);
		font-size: var(--text-small);
		line-height: var(--leading-normal);
		margin: 0;
	}

	/* --- Columns --- */

	.footer__columns {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-6);
	}

	.footer__heading {
		font-family: var(--font-mono);
		font-size: var(--text-small);
		font-weight: var(--weight-medium);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: var(--text-muted);
		margin-block-end: var(--space-4);
	}

	.footer__column ul {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.footer__column a {
		color: var(--text-secondary);
		text-decoration: underline;
		text-decoration-color: var(--border);
		text-underline-offset: 0.2em;
		text-decoration-thickness: 1px;
		font-size: var(--text-small);
		transition:
			color var(--transition-fast),
			text-decoration-color var(--transition-fast);
		line-height: var(--leading-normal);
	}

	.footer__column a:hover,
	.footer__column a:focus-visible {
		color: var(--text-primary);
		text-decoration-color: var(--text-primary);
	}

	/* External link indicator */
	.footer__external::after {
		content: " ↗";
		font-size: 0.75em;
		opacity: 0.6;
	}

	/* --- Bottom --- */

	.footer__bottom {
		border-top: 1px solid var(--border);
		padding-block-start: var(--space-5);
	}

	.footer__bottom p {
		color: var(--text-muted);
		font-size: var(--text-small);
		margin: 0;
	}

	.footer__version {
		font-family: var(--font-mono);
		color: var(--text-muted);
		font-size: var(--text-small);
	}

	.footer__bottom-link {
		color: var(--text-secondary);
		text-decoration: none;
		transition:
			color var(--transition-fast),
			text-decoration var(--transition-fast);
	}

	.footer__bottom-link:hover,
	.footer__bottom-link:focus-visible {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 0.2em;
		text-decoration-thickness: 1px;
	}

	/* --- Responsive --- */

	@media (min-width: 768px) {
		.footer__columns {
			grid-template-columns: repeat(3, 1fr);
		}

		.footer__inner {
			display: grid;
			grid-template-columns: 1fr 2fr;
			grid-template-rows: auto auto;
			gap: var(--space-7);
		}

		.footer__brand {
			grid-column: 1;
			grid-row: 1;
		}

		.footer__columns {
			grid-column: 2;
			grid-row: 1;
		}

		.footer__bottom {
			grid-column: 1 / -1;
			grid-row: 2;
		}
	}
</style>
