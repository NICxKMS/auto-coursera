---
const currentYear = new Date().getFullYear();

interface FooterLink {
	label: string;
	href: string;
	external?: boolean;
}

const footerSections: { title: string; links: FooterLink[] }[] = [
	{
		title: 'Product',
		links: [
			{ label: 'Install', href: '/install' },
			{ label: 'Downloads', href: '/downloads' },
			{ label: 'Releases', href: '/releases' },
		],
	},
	{
		title: 'Resources',
		links: [
			{ label: 'Documentation', href: '/docs' },
			{ label: 'Manual Install', href: '/docs/manual' },
			{ label: 'Troubleshooting', href: '/docs/troubleshoot' },
			{ label: 'GitHub', href: 'https://github.com/nicxkms/auto-coursera', external: true },
		],
	},
	{
		title: 'Legal',
		links: [
			{ label: 'Privacy Policy', href: '/privacy' },
			{
				label: 'License',
				href: 'https://github.com/nicxkms/auto-coursera/blob/main/LICENSE',
				external: true,
			},
		],
	},
];
---

<footer class="relative mt-24" role="contentinfo">
  <!-- Top gradient divider -->
  <div class="divider-glow" aria-hidden="true"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="py-16 sm:py-20 grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-10 lg:gap-14">

      <!-- Brand column -->
      <div class="col-span-2 sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 text-white hover:text-white group mb-5">
          <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-br from-primary-500 to-primary-700 shadow-lg shadow-primary-600/20">
            <svg class="w-4 h-4 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"></path>
              <path d="M2 17l10 5 10-5"></path>
              <path d="M2 12l10 5 10-5"></path>
            </svg>
          </div>
          <span class="text-base font-bold tracking-tight">Auto-Coursera</span>
        </a>
        <p class="text-sm text-surface-500 leading-relaxed max-w-[240px]">
          AI-powered answer assistant for Coursera. Private, fast, and open-source.
        </p>
      </div>

      <!-- Link columns -->
      {footerSections.map((section) => (
        <div>
          <h3 class="text-xs font-semibold text-surface-400 uppercase tracking-widest mb-4">
            {section.title}
          </h3>
          <ul class="space-y-3">
            {section.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-surface-500 hover:text-surface-200 transition-colors duration-200 inline-flex items-center gap-1.5"
                  {...(link.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {link.label}
                  {link.external && (
                    <svg class="w-3 h-3 opacity-40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
                      <polyline points="15 3 21 3 21 9"></polyline>
                      <line x1="10" y1="14" x2="21" y2="3"></line>
                    </svg>
                  )}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/[0.04] py-6 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-surface-400">
        &copy; 2024&ndash;{currentYear} nicx. All rights reserved.
      </p>
      <p class="text-xs text-surface-400">
        Built with <span class="text-primary-400/60">&hearts;</span> by nicx
      </p>
    </div>
  </div>
</footer>
