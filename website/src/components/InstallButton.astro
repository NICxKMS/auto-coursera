---
interface Props {
	os: 'windows' | 'macos' | 'linux';
	label: string;
	href: string;
	recommended?: boolean;
	size?: string;
}

const { os, label, href, recommended = false, size } = Astro.props;

const osIcons: Record<string, string> = {
	windows: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M3 12V6.5l8-1.1V12H3zm0 .5h8v6.6l-8-1.1V12.5zM11.5 12V5.3l9.5-1.3V12h-9.5zm0 .5H21v7.5l-9.5-1.3v-6.2z"/></svg>`,
	macos: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>`,
	linux: `<svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M12.504 0c-.155 0-.311.004-.466.013a7.18 7.18 0 0 0-.375.031c-.625.063-1.15.218-1.578.465-.844.49-1.316 1.297-1.512 2.18a6.73 6.73 0 0 0-.117.875 8.59 8.59 0 0 0 .004.965c.03.434.09.852.18 1.242.094.39.21.75.344 1.074.094.227.199.437.312.625.094.155.203.3.32.441.086.102.152.168.152.168l.008.008c.082.07.168.137.258.2.219.153.468.27.742.352.262.078.547.117.848.117s.586-.04.848-.117c.274-.082.523-.2.742-.352.09-.063.176-.13.258-.2l.008-.008s.066-.066.152-.168c.117-.14.227-.286.32-.441.114-.188.219-.398.313-.625.133-.324.25-.684.344-1.074.09-.39.148-.808.18-1.242a8.59 8.59 0 0 0 .003-.965 6.73 6.73 0 0 0-.117-.875c-.196-.883-.668-1.69-1.512-2.18a3.76 3.76 0 0 0-1.578-.465 7.95 7.95 0 0 0-.375-.031A5.7 5.7 0 0 0 12.504 0zM6.28 8.4c-.906 0-1.641.254-2.164.691-.578.488-.957 1.207-1.129 2.102-.066.34-.101.703-.101 1.09 0 1.094.316 2.293.902 3.434.293.57.637 1.11 1.03 1.613.39.504.833.965 1.318 1.36.727.59 1.55 1.03 2.434 1.261.437.114.887.168 1.344.168.578 0 1.129-.09 1.636-.27.45-.16.867-.389 1.242-.68l.008-.008a7.222 7.222 0 0 0 .672-.605c.25-.25.48-.516.692-.793.425-.563.762-1.176 1.004-1.82.164-.438.285-.891.363-1.355.039-.23.066-.461.082-.695a7.5 7.5 0 0 0 .012-.492c0-.664-.098-1.297-.285-1.87a4.14 4.14 0 0 0-.84-1.53c-.39-.44-.86-.785-1.399-1.016-.543-.23-1.152-.348-1.824-.348-.34 0-.668.031-.98.094a4.86 4.86 0 0 0-.888.27c-.273.108-.527.24-.762.394a6.38 6.38 0 0 0-.344.25 6.15 6.15 0 0 0-.344-.25 4.42 4.42 0 0 0-.762-.394 4.49 4.49 0 0 0-.887-.27A5.02 5.02 0 0 0 6.28 8.4z"/></svg>`,
};
---

<a
  href={href}
  data-os={os}
  class:list={[
    'install-card group relative flex items-center gap-5 px-6 py-5 rounded-xl font-medium transition-all duration-300',
    'focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary-500',
    recommended
      ? 'bg-gradient-to-r from-primary-600/20 to-primary-500/10 border border-primary-500/25 shadow-lg shadow-primary-500/10 hover:shadow-glow-lg hover:border-primary-400/40 hover:-translate-y-1'
      : 'glass hover:bg-white/[0.05] hover:border-white/[0.12] hover:-translate-y-1 hover:shadow-glow',
  ]}
>
  {recommended && (
    <span class="absolute -top-3 right-5 inline-flex items-center gap-1 px-3 py-1 rounded-full text-xs font-semibold bg-gradient-to-r from-accent-500 to-accent-400 text-surface-950 shadow-lg shadow-accent-500/30">
      <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
      </svg>
      Recommended
    </span>
  )}

  <!-- OS Icon -->
  <span
    class:list={[
      'flex items-center justify-center w-12 h-12 rounded-xl shrink-0 transition-all duration-300',
      recommended
        ? 'bg-primary-500/15 text-primary-300 group-hover:bg-primary-500/25'
        : 'bg-white/[0.04] text-surface-400 group-hover:bg-white/[0.08] group-hover:text-white',
    ]}
    set:html={osIcons[os] || osIcons.linux}
  />

  <!-- Label & Size -->
  <span class="flex flex-col items-start gap-0.5">
    <span class:list={['text-base leading-tight', recommended ? 'text-white' : 'text-surface-200']}>
      {label}
    </span>
    {size && (
      <span class:list={['text-xs', recommended ? 'text-primary-300/60' : 'text-surface-500']}>
        {size}
      </span>
    )}
  </span>

  <!-- Arrow -->
  <svg
    class:list={[
      'w-5 h-5 ml-auto shrink-0 transition-all duration-300',
      recommended
        ? 'text-primary-400/40 group-hover:text-primary-300 group-hover:translate-x-1'
        : 'text-surface-600 group-hover:text-surface-300 group-hover:translate-x-1',
    ]}
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M5 12h14"></path>
    <path d="m12 5 7 7-7 7"></path>
  </svg>
</a>
